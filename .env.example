# ═══════════════════════════════════════════════════════
# TutisCloud — Environment Configuration
# Copy to .env and fill in your values
# ═══════════════════════════════════════════════════════

# ─── Database (PostgreSQL via Prisma) ────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/tutiscloud"

# ─── Better Auth ─────────────────────────────────────
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="your-secret-key-change-in-production"
BETTER_AUTH_URL="http://localhost:3000"

# ─── Email (Resend) ──────────────────────────────────
RESEND_API_KEY="re_..."
EMAIL_FROM="TutisCloud <noreply@yourdomain.com>"

# ─── Stripe ──────────────────────────────────────────
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# ─── AWS S3 Storage ──────────────────────────────────
AWS_ACCESS_KEY_ID="your-access-key"
AWS_SECRET_ACCESS_KEY="your-secret-key"
AWS_REGION="us-east-1"
S3_BUCKET_NAME="tutiscloud-files"
S3_ENDPOINT="https://s3.amazonaws.com"  # Optional: for S3-compatible storage

# ─── Redis (BullMQ / Rate Limiting) ──────────────────
REDIS_URL="redis://localhost:6379"

# ─── App ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
APP_VERSION="1.0.0"

# ─── Development ─────────────────────────────────────
NODE_ENV="development"
